{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/vcompany/tools/ask_discord.py",
            "timeout": 86400
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "vco signal --ready --agent-id ${VCO_AGENT_ID}"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "vco signal --idle --agent-id ${VCO_AGENT_ID}"
          }
        ]
      }
    ]
  }
}
